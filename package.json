{
  "name": "desktop-note",
  "version": "2.6.0",
  "description": "A calm, local-first daily note and checklist for the Windows desktop.",
  "author": "Wang335533",
  "license": "MIT",
  "homepage": "https://github.com/Wang335533/Note#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wang335533/Note.git"
  },
  "bugs": {
    "url": "https://github.com/Wang335533/Note/issues"
  },
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "exports": {
    "./store": "./shared/store.cjs",
    "./library-files": {
      "import": "./shared/library-files.mjs",
      "require": "./shared/library-files.cjs"
    },
    "./rich-text": "./shared/rich-text.cjs"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop:dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "sync:icon": "node scripts/sync-icon.mjs",
    "build": "npm run sync:icon && vite build && node scripts/verify-dist.mjs",
    "smoke:desktop": "node scripts/smoke-desktop.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && electron .",
    "test": "node --test tests/*.test.cjs tests/*.test.mjs",
    "package:installer": "npm run build && electron-builder --win nsis --publish never",
    "package:fast": "npm run build && electron-builder --win dir"
  },
  "devDependencies": {
    "@floating-ui/dom": "1.8.0",
    "@phosphor-icons/core": "2.1.1",
    "@phosphor-icons/react": "2.1.10",
    "@tiptap/core": "3.28.0",
    "@tiptap/extension-image": "3.28.0",
    "@tiptap/extension-mathematics": "3.28.0",
    "@tiptap/extension-table": "3.28.0",
    "@tiptap/extension-task-item": "3.28.0",
    "@tiptap/extension-task-list": "3.28.0",
    "@tiptap/extension-text-align": "3.28.0",
    "@tiptap/extension-text-style": "3.28.0",
    "@tiptap/extensions": "3.28.0",
    "@tiptap/html": "3.28.0",
    "@tiptap/pm": "3.28.0",
    "@tiptap/react": "3.28.0",
    "@tiptap/starter-kit": "3.28.0",
    "@vitejs/plugin-react": "5.0.4",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "katex": "0.17.0",
    "marked": "18.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "0.35.3",
    "vite": "6.4.3",
    "wait-on": "9.0.10"
  },
  "overrides": {
    "shell-quote": "1.10.0"
  },
  "build": {
    "appId": "local.desktop.note",
    "productName": "Note",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "assets/**/*",
      "package.json"
    ],
    "electronLanguages": [
      "zh-CN",
      "zh-TW",
      "en-US"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/note.png"
    },
    "nsis": {
      "artifactName": "Note-${version}-setup.${ext}",
      "differentialPackage": false,
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
